# Mod Button (Windows Key)
set $mod Mod4

# Font
font pango:JetBrainsMono Nerd Font 10

# Move Window (Mod + left + click)
floating_modifier $mod

# --- DEFAULT APP ---
# Default terminal (wezterm)
bindsym $mod+Return exec i3-sensible-terminal

# Aplication Menu (rofi)
bindsym $mod+r exec --no-startup-id rofi -show drun

# Rofi exit
bindsym $mod+e exec --no-startup-id ~/.config/rofi/scripts/power.sh

# Rofi wallpapaers
bindsym $mod+w exec --no-startup-id ~/.config/rofi/scripts/wall-picker.sh

# Screenshot scrot
bindsym --release Print exec "scrot -f ~/Pictures/i3-screenshots/normal/%Y%m%d-%H%M%S.png && notify-send 'Screenshot' 'Screenshot Success'"

# Delay screenshot
bindsym --release Shift+Print exec "notify-send 'Screenshot' 'Delay Screenshot (5s)' | scrot -d 5 -f ~/Pictures/i3-screenshots/delay/%Y%m%d-%H%M%S.png && notify-send 'Screenshot' 'Screenshot Success'"

# Area Screenshot (Mod + Print)
bindsym --release $mod+Print exec "scrot -s -f ~/Pictures/i3-screenshots/area/%Y%m%d-%H%M%S.png && notify-send 'Screenshot' 'Screenshot Success' || notify-send 'Screenshot' 'Screenshot Abort'" 

# Rofi music player
bindsym $mod+m exec --no-startup-id ~/.config/rofi/scripts/music-menu.sh

# File manager (Thunar)
bindsym $mod+t exec thunar

# Brave-origin
bindsym $mod+b exec brave-origin

# Nmcli
bindsym $mod+n exec --no-startup-id ~/.config/rofi/scripts/nmcli.sh

# --- SCREEN & AUDIO SETTINGS (Fungsi Tombol Laptop) ---
# Brightness (Brightnessctl + Dunst)
bindsym XF86MonBrightnessUp   exec --no-startup-id brightnessctl set +5% && ~/.config/dunst/scripts/bright-noti.sh
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%- && ~/.config/dunst/scripts/bright-noti.sh

# Volume Audio (pactl + Dunst)
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && ~/.config/dunst/scripts/vol-noti.sh
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && ~/.config/dunst/scripts/vol-noti.sh
bindsym XF86AudioMute        exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && ~/.config/dunst/scripts/vol-noti.sh

# --- WINDOW ---
# Kill window
bindsym $mod+q kill

# Change focus window (arrow)
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move active window (arrow)
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Resize
bindsym CTRL+Left resize shrink width 10 px or 10 ppt
bindsym CTRL+Down resize grow height 10 px or 10 ppt
bindsym CTRL+Up resize shrink height 10 px or 10 ppt
bindsym CTRL+Right resize grow width 10 px or 10 ppt


# --- WORKSPACES ---
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5

bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle resize set 660 px 420 px, move position center

# --- AUTOSTART ---
# Wallpaper (nitrogen)
exec_always --no-startup-id nitrogen --restore
# Compositor Picom
exec_always --no-startup-id picom --config ~/.config/picom/picom.conf
# Polybar
exec_always --no-startup-id polybar top
# autotiling
exec_always --no-startup-id autotiling --limit 2
# Dunst
exec --no-startup-id dunst
# Run music daemon
exec --no-startup-id ~/.config/rofi/scripts/music-daemon.sh

# --- SYSTEM ---
# Restart i3
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# i3-gaps
gaps inner 4
gaps outer 2

for_window [class=".*"] border pixel 0
